{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.test/nlp-policy-nz/track22/nz_mleb_fixture.schema.json",
  "title": "Track 22 NZ-MLEB Local Fixture",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "jurisdiction", "documents", "queries"],
  "properties": {
    "schema_version": {"const": "track22.nz-mleb.fixture.v1"},
    "jurisdiction": {"const": "NZ"},
    "documents": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["doc_id", "title", "source_type", "jurisdiction", "text"],
        "properties": {
          "doc_id": {"type": "string", "minLength": 1},
          "title": {"type": "string", "minLength": 1},
          "source_type": {"enum": ["legislation", "hansard", "court_decision"]},
          "jurisdiction": {"const": "NZ"},
          "citation": {"type": "string"},
          "text": {"type": "string", "minLength": 20}
        }
      }
    },
    "queries": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["query_id", "query_text", "jurisdiction", "task", "judgements"],
        "properties": {
          "query_id": {"type": "string", "pattern": "^nz-mleb-[0-9]{3}$"},
          "query_text": {"type": "string", "minLength": 10},
          "jurisdiction": {"const": "NZ"},
          "task": {"enum": ["citation-search", "policy-similarity", "case-retrieval"]},
          "judgements": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["doc_id", "relevance", "rationale"],
              "properties": {
                "doc_id": {"type": "string", "minLength": 1},
                "relevance": {"type": "integer", "minimum": 0, "maximum": 3},
                "rationale": {"type": "string", "minLength": 10}
              }
            }
          }
        }
      }
    }
  }
}
