{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Track 26 Ontology Standards Registry",
  "type": "object",
  "required": [
    "schema_version",
    "registry_name",
    "entries",
    "summary",
    "license_assumptions",
    "registry_notes"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "registry_name": {
      "const": "track26_standards_registry"
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "standard",
          "source_url",
          "source_license",
          "local_representation_paths",
          "implementation_status",
          "blocker_type",
          "blocker_source",
          "notes"
        ],
        "properties": {
          "standard": {
            "type": "string",
            "minLength": 1
          },
          "source_url": {
            "type": "string",
            "minLength": 1
          },
          "source_license": {
            "type": "string",
            "minLength": 1
          },
          "local_representation_paths": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "implementation_status": {
            "enum": [
              "implemented",
              "partial",
              "scaffolded",
              "adjacent",
              "missing"
            ]
          },
          "blocker_type": {
            "enum": [
              "none",
              "data",
              "specification",
              "integration"
            ]
          },
          "blocker_source": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "summary": {
      "type": "object"
    },
    "license_assumptions": {
      "type": "array"
    },
    "registry_notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
