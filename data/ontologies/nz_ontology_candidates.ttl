evidence:coverage-akn-legal-docml-ecli a prov:Entity ;
    dcterms:source "src/nlp_policy_nz/schema/akn_v3.py, src/nlp_policy_nz/universal_framework_v3.py" ;
    rdf:value "missing coverage for ECLI: Judgment support exists, but not the authoritative citation layer." ;
