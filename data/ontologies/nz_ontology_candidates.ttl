nzvocab:court-levels a skos:ConceptScheme ;
    skos:definition "Controlled vocabulary for New Zealand court hierarchy levels." ;
    skos:prefLabel "NZ court levels" .

nzvocab:government-agencies a skos:ConceptScheme ;
    skos:definition "Controlled vocabulary for public sector actor classes." ;
    skos:prefLabel "NZ government agencies" .

nzvocab:hansard-topics a skos:ConceptScheme ;
    skos:definition "Controlled vocabulary for high-level parliamentary debate topics." ;
    skos:prefLabel "Hansard topics" .

nzvocab:maori-legal-concepts a skos:ConceptScheme ;
    skos:definition "Controlled vocabulary for Māori legal and policy concepts." ;
    skos:prefLabel "Māori legal concepts" .

nzvocab:nz-act-types a skos:ConceptScheme ;
    skos:definition "Controlled vocabulary for New Zealand legislative document types." ;
    skos:prefLabel "NZ Act types" .

