    map:sourceStandard "LKIF" ;
    map:sourceTerm "Obligation" ;
    map:targetNode <https://legal-nz.example.org/ontology/standards/akoma-ntoso/obligation> ;
    map:targetStandard "Akoma Ntoso" ;
    map:targetTerm "obligation" .

