map:agls-resource-to-nzgls-resource a map:MappingRecord ;
    dc:identifier "agls-resource-to-nzgls-resource" ;
    dcterms:source "data/ontologies/track28_standards_registry_addendum.json" ;
    rdfs:comment "Supports AU-to-NZ corpus metadata transfer without adopting AGLS as core." ;
    map:confidence 0.8 ;
    map:mappingPredicate "skos:closeMatch" ;
    map:method "manual trans-Tasman metadata crosswalk" ;
    map:reviewStatus "approved" ;
    map:sourceNode <https://legal-nz.example.org/ontology/standards/agls/resource> ;
    map:sourceStandard "AGLS" ;
    map:sourceTerm "Resource" ;
    map:targetNode <https://legal-nz.example.org/ontology/standards/nzgls/resource> ;
    map:targetStandard "NZGLS" ;
    map:targetTerm "Resource" .

map:dcat-dataset-to-data-govt-nz-dataset a map:MappingRecord ;
