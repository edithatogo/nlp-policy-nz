    map:sourceTerm "Person" ;
    map:targetNode <https://legal-nz.example.org/ontology/standards/schema-org/person> ;
    map:targetStandard "schema.org" ;
    map:targetTerm "Person" .

map:lkif-obligation-to-akn-obligation a map:MappingRecord ;
