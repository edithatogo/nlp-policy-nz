map:extraction-date-to-time-instant a map:MappingRecord ;
    dc:identifier "extraction-date-to-time-instant" ;
    dcterms:source "src/nlp_policy_nz/extraction/schemas.py" ;
    rdfs:comment "Only normalized dates with source spans should be mapped to Time entities." ;
    map:confidence 0.76 ;
    map:mappingPredicate "skos:closeMatch" ;
    map:method "manual extraction-family to W3C Time crosswalk" ;
    map:reviewStatus "approved" ;
    map:sourceNode <https://legal-nz.example.org/ontology/standards/nlp-policy-nz-extraction/date> ;
    map:sourceStandard "nlp-policy-nz extraction" ;
    map:sourceTerm "date" ;
    map:targetNode <https://legal-nz.example.org/ontology/standards/owl-time/time-instant> ;
    map:targetStandard "OWL-Time" ;
    map:targetTerm "time:Instant" .

map:extraction-definition-to-skos-concept a map:MappingRecord ;
    dc:identifier "extraction-definition-to-skos-concept" ;
    dcterms:source "src/nlp_policy_nz/extraction/schemas.py" ;
