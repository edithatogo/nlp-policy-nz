    map:sourceStandard "DCAT" ;
    map:sourceTerm "Dataset" ;
    map:targetNode <https://legal-nz.example.org/ontology/standards/data-govt-nz-dataset-metadata/dataset> ;
    map:targetStandard "data.govt.nz Dataset Metadata" ;
    map:targetTerm "dataset" .

