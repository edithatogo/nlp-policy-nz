{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "schedule:weekly",
    "group:allNonMajor",
    ":semanticCommitTypeAll(chore)",
    ":automergeMinor",
    ":automergePr",
    ":automergeRequireAllStatusChecks",
    ":disableDependencyDashboard",
    ":automergeBranch"
  ],
  "timezone": "Pacific/Auckland",
  "schedule": ["before 6am on Monday"],
  "labels": ["dependencies", "automated"],
  "packageRules": [
    {
      "groupName": "All Dependencies (Auto-merge)",
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "branch",
      "automergeStrategy": "fast-forward",
      "commitMessagePrefix": "chore(deps):",
      "labels": ["dependencies", "automated", "auto-merge"]
    },
    {
      "groupName": "Major Dependencies (Require Review)",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "commitMessagePrefix": "chore(deps)!: ",
      "labels": ["dependencies", "major-update", "requires-review"]
    },
    {
      "groupName": "GitHub Actions (Auto-merge)",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "branch",
      "commitMessagePrefix": "chore(ci):",
      "labels": ["dependencies", "github-actions", "automated", "auto-merge"]
    },
    {
      "groupName": "Python Dependencies (Auto-merge)",
      "matchManagers": ["pep621"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "branch",
      "commitMessagePrefix": "chore(deps):",
      "labels": ["dependencies", "python", "automated", "auto-merge"]
    },
    {
      "groupName": "Pre-commit Hooks (Auto-merge)",
      "matchManagers": ["pre-commit"],
      "automerge": true,
      "automergeType": "branch",
      "commitMessagePrefix": "chore(deps):",
      "labels": ["dependencies", "pre-commit", "automated", "auto-merge"]
    }
  ],
  "pep621": {
    "enabled": true
  },
  "github-actions": {
    "enabled": true
  },
  "pre-commit": {
    "enabled": true
  },
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "rangeStrategy": "bump",
  "separateMajorMinor": true,
  "separateMultipleMajor": false,
  "separateMinorPatch": true,
  "stabilityDays": 0,
  "dependencyDashboard": false,
  "suppressNotifications": ["prEditedNotification", "prAutomergedNotification"],
  "rebaseWhen": "behind-base-branch",
  "platformAutomerge": true,
  "ignoreTests": false
}
